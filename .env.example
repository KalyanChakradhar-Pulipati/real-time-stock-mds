# Environment variables - COPY THIS TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git - it's in .gitignore

# ============================================
# SNOWFLAKE CONFIGURATION
# ============================================
# Get these from your Snowflake account
# Account ID: Settings > Account > Account Identifier
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DB=STOCKS_MDS
SNOWFLAKE_SCHEMA=COMMON

# ============================================
# FINNHUB API CONFIGURATION
# ============================================
# Get API key from: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_BASE_URL=https://finnhub.io/api/v1/quote

# ============================================
# MINIO CONFIGURATION (Local Docker)
# ============================================
# For local development, you can use any values
# These are the default MinIO credentials
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=bronze-stock-data-bucket

# ============================================
# APPLICATION CONFIGURATION
# ============================================
LOCAL_DIR=/tmp/minio_downloads
STOCK_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA
